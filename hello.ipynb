   "source": [
    "import re\n",
    "\n",
    "# Example input\n",
    "text = \"A quick brown fox jumps over a lazy dog aaatest.\"\n",
    "\n",
    "# Your regex pattern here\n",
    "pattern = r\"^[Aa]|(?![^B-Zb-z0-9])+[Aa]+[B-Zb-z0-9]*\"\n",
    "\n",
    "# Find all matches\n",
    "words = re.findall(pattern, text)\n",
    "print(words)"
   ]
  }
 ],
